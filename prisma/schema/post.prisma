model Post {
  id         String     @id @default(uuid())
  title      String     @db.VarChar(255)
  content    String     @db.Text
  thumbnail  String?
  isFeatured Boolean    @default(false)
  status     PostStatus @default(DRAFT)
  tags       String[]
  views      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("posts")
}
